# --- Airtable (required) ---
AIRTABLE_API_KEY=your_airtable_personal_access_token
AIRTABLE_BASE_ID=appTFkAe9KWVMP3It
AIRTABLE_QUESTIONS_TABLE=Image Questions

# --- Clerk (OPTIONAL — only needed for the "save my progress" sign-in) ---
# Leave these UNSET and the app runs fully anonymous (progress saved in the browser).
# Set them to enable optional accounts + cloud-synced progress.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- Vercel Blob (set automatically when you create a Blob store; used by the image upload script) ---
BLOB_READ_WRITE_TOKEN=

# --- Preview ---
# Set to "true" to show unpublished [DRAFT] questions too (use on a preview deploy, not production).
NEXT_PUBLIC_SHOW_DRAFTS=false
